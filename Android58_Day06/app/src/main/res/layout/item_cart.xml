<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_cart_item">

    <ImageView
        android:id="@+id/cart_product_image"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:scaleType="centerInside"
        android:contentDescription="Product" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/cart_product_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Product Name"
            android:textSize="14sp"
            android:textStyle="bold" />

        <RatingBar
            android:id="@+id/cart_rating_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:rating="4.5"
            android:isIndicator="true"
            style="?android:attr/ratingBarStyleSmall"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/cart_product_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$12"
            android:textSize="12sp"
            android:textColor="@color/gray"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <ImageButton
            android:id="@+id/cart_decrease_btn"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_tru"
            android:background="@drawable/bg_quantity_btn"
            android:contentDescription="Decrease" />

        <TextView
            android:id="@+id/cart_quantity"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="0"
            android:textSize="12sp" />

        <ImageButton
            android:id="@+id/cart_increase_btn"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_cong"
            android:background="@drawable/bg_quantity_btn"
            android:contentDescription="Increase" />
    </LinearLayout>
</LinearLayout>